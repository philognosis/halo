@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix stf:  <http://enterprise.org/staffing/> .
@prefix dc:   <http://purl.org/dc/elements/1.1/> .

# =============================================================================
# Concept Scheme
# =============================================================================

stf:SkillScheme a skos:ConceptScheme ;
    dc:title "Enterprise Staffing Skill Taxonomy" ;
    dc:description "SKOS concept scheme for classifying consultant competencies. "
                   "Aligned with ESCO (European Skills/Competences) label conventions "
                   "and used as the skill vocabulary in the staffing ontology." ;
    skos:prefLabel "Enterprise Skill Taxonomy"@en ;
    skos:hasTopConcept stf:TechnicalSkills ;
    skos:hasTopConcept stf:FunctionalSkills ;
    skos:hasTopConcept stf:LeadershipSkills ;
    skos:hasTopConcept stf:DomainSkills .

# =============================================================================
# TOP-LEVEL CONCEPTS
# =============================================================================

stf:TechnicalSkills a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:topConceptOf stf:SkillScheme ;
    skos:prefLabel "Technical Skills"@en ;
    skos:altLabel "Tech Skills"@en ;
    skos:notation "TechnicalSkills" ;
    skos:definition "Skills relating to the design, development, deployment and "
                    "operation of software, data, and cloud systems."@en ;
    skos:narrower stf:DataEngineering ;
    skos:narrower stf:SoftwareDevelopment ;
    skos:narrower stf:CloudPlatforms ;
    skos:narrower stf:DataScience ;
    skos:narrower stf:Analytics .

stf:FunctionalSkills a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:topConceptOf stf:SkillScheme ;
    skos:prefLabel "Functional Skills"@en ;
    skos:altLabel "Business Skills"@en ;
    skos:notation "FunctionalSkills" ;
    skos:definition "Cross-cutting business capabilities relevant to consulting "
                    "engagements regardless of industry."@en ;
    skos:narrower stf:StrategyConsulting ;
    skos:narrower stf:ChangeManagement ;
    skos:narrower stf:PMO ;
    skos:narrower stf:BusinessAnalysis ;
    skos:narrower stf:ProcessImprovement .

stf:LeadershipSkills a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:topConceptOf stf:SkillScheme ;
    skos:prefLabel "Leadership Skills"@en ;
    skos:notation "LeadershipSkills" ;
    skos:definition "Skills related to people leadership, stakeholder engagement, "
                    "and executive presence in a consulting context."@en ;
    skos:narrower stf:TeamLeadership ;
    skos:narrower stf:StakeholderManagement ;
    skos:narrower stf:ExecutivePresence ;
    skos:narrower stf:ClientRelationships .

stf:DomainSkills a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:topConceptOf stf:SkillScheme ;
    skos:prefLabel "Domain Skills"@en ;
    skos:altLabel "Industry Knowledge"@en ;
    skos:notation "DomainSkills" ;
    skos:definition "Deep expertise in a specific industry vertical or business domain."@en ;
    skos:narrower stf:FinancialServices ;
    skos:narrower stf:Healthcare ;
    skos:narrower stf:Energy ;
    skos:narrower stf:Retail ;
    skos:narrower stf:Technology ;
    skos:narrower stf:Manufacturing .

# =============================================================================
# TECHNICAL SKILLS — Mid-level categories
# =============================================================================

stf:DataEngineering a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Data Engineering"@en ;
    skos:altLabel "DE"@en ;
    skos:altLabel "Data Eng"@en ;
    skos:notation "DataEngineering" ;
    skos:definition "The practice of designing and building scalable pipelines, "
                    "warehouses, and lakehouses for large-scale data processing."@en ;
    skos:broader stf:TechnicalSkills ;
    skos:narrower stf:Python ;
    skos:narrower stf:Spark ;
    skos:narrower stf:SQL ;
    skos:narrower stf:Kafka ;
    skos:narrower stf:dbt .

stf:SoftwareDevelopment a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Software Development"@en ;
    skos:altLabel "SWE"@en ;
    skos:notation "SoftwareDevelopment" ;
    skos:definition "Design, implementation, testing and maintenance of software "
                    "applications and services."@en ;
    skos:broader stf:TechnicalSkills ;
    skos:narrower stf:Java ;
    skos:narrower stf:React ;
    skos:narrower stf:TypeScript ;
    skos:narrower stf:Microservices .

stf:CloudPlatforms a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Cloud Platforms"@en ;
    skos:altLabel "Cloud"@en ;
    skos:notation "CloudPlatforms" ;
    skos:definition "Skills in designing, deploying and operating workloads on "
                    "public cloud infrastructure providers."@en ;
    skos:broader stf:TechnicalSkills ;
    skos:narrower stf:AWS ;
    skos:narrower stf:GCP ;
    skos:narrower stf:Azure .

stf:DataScience a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Data Science"@en ;
    skos:altLabel "DS"@en ;
    skos:notation "DataScience" ;
    skos:definition "The application of statistical and machine-learning techniques "
                    "to extract insights and build predictive models from data."@en ;
    skos:broader stf:TechnicalSkills ;
    skos:narrower stf:MachineLearning ;
    skos:narrower stf:DeepLearning ;
    skos:narrower stf:NLP .

stf:Analytics a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Analytics"@en ;
    skos:altLabel "BI"@en ;
    skos:notation "Analytics" ;
    skos:definition "Business intelligence and reporting disciplines including "
                    "dashboarding, KPI design and self-service analytics."@en ;
    skos:broader stf:TechnicalSkills .

# =============================================================================
# DATA ENGINEERING narrower concepts
# =============================================================================

stf:Python a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Python"@en ;
    skos:notation "Python" ;
    skos:definition "The Python programming language, widely used for data "
                    "engineering, data science, scripting and backend services."@en ;
    skos:broader stf:DataEngineering .

stf:Spark a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Apache Spark"@en ;
    skos:altLabel "Spark"@en ;
    skos:notation "Spark" ;
    skos:definition "Distributed data processing framework for large-scale batch "
                    "and streaming analytics."@en ;
    skos:broader stf:DataEngineering .

stf:SQL a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "SQL"@en ;
    skos:altLabel "Structured Query Language"@en ;
    skos:notation "SQL" ;
    skos:definition "Structured Query Language for relational database querying "
                    "and data manipulation."@en ;
    skos:broader stf:DataEngineering .

stf:Kafka a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Apache Kafka"@en ;
    skos:altLabel "Kafka"@en ;
    skos:notation "Kafka" ;
    skos:definition "Distributed event streaming platform used for real-time data "
                    "pipelines and stream processing."@en ;
    skos:broader stf:DataEngineering .

stf:dbt a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "dbt"@en ;
    skos:altLabel "Data Build Tool"@en ;
    skos:notation "dbt" ;
    skos:definition "SQL-first transformation framework for analytics engineering "
                    "and ELT workflows."@en ;
    skos:broader stf:DataEngineering .

# =============================================================================
# CLOUD PLATFORMS narrower concepts
# =============================================================================

stf:AWS a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Amazon Web Services"@en ;
    skos:altLabel "AWS"@en ;
    skos:notation "AWS" ;
    skos:definition "Amazon's cloud computing platform offering IaaS, PaaS and SaaS "
                    "services including compute, storage, databases and ML."@en ;
    skos:broader stf:CloudPlatforms .

stf:GCP a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Google Cloud Platform"@en ;
    skos:altLabel "GCP"@en ;
    skos:altLabel "Google Cloud"@en ;
    skos:notation "GCP" ;
    skos:definition "Google's cloud computing platform including BigQuery, Vertex AI "
                    "and Kubernetes Engine."@en ;
    skos:broader stf:CloudPlatforms .

stf:Azure a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Microsoft Azure"@en ;
    skos:altLabel "Azure"@en ;
    skos:notation "Azure" ;
    skos:definition "Microsoft's cloud platform offering a wide range of services "
                    "including Azure Data Factory, Synapse and OpenAI integration."@en ;
    skos:broader stf:CloudPlatforms .

# =============================================================================
# DATA SCIENCE narrower concepts
# =============================================================================

stf:MachineLearning a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Machine Learning"@en ;
    skos:altLabel "ML"@en ;
    skos:notation "MachineLearning" ;
    skos:definition "The practice of building models that learn patterns from data "
                    "to make predictions or decisions."@en ;
    skos:broader stf:DataScience ;
    skos:narrower stf:PyTorch ;
    skos:narrower stf:TensorFlow .

stf:DeepLearning a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Deep Learning"@en ;
    skos:altLabel "DL"@en ;
    skos:notation "DeepLearning" ;
    skos:definition "A subfield of machine learning using multi-layer neural networks "
                    "for tasks such as image recognition and language modelling."@en ;
    skos:broader stf:DataScience .

stf:NLP a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Natural Language Processing"@en ;
    skos:altLabel "NLP"@en ;
    skos:notation "NLP" ;
    skos:definition "Techniques for processing and understanding human language, "
                    "including text classification, entity recognition and generation."@en ;
    skos:broader stf:DataScience .

stf:ArtificialIntelligence a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Artificial Intelligence"@en ;
    skos:altLabel "AI"@en ;
    skos:notation "ArtificialIntelligence" ;
    skos:definition "Broad discipline encompassing machine learning, knowledge "
                    "representation, planning and generative AI systems."@en ;
    skos:broader stf:DataScience .

stf:PyTorch a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "PyTorch"@en ;
    skos:notation "PyTorch" ;
    skos:definition "Open-source deep learning framework developed by Meta, widely "
                    "used for research and production ML models."@en ;
    skos:broader stf:MachineLearning .

stf:TensorFlow a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "TensorFlow"@en ;
    skos:notation "TensorFlow" ;
    skos:definition "Open-source deep learning framework developed by Google, used "
                    "for large-scale model training and deployment."@en ;
    skos:broader stf:MachineLearning .

# =============================================================================
# SOFTWARE DEVELOPMENT narrower concepts
# =============================================================================

stf:Java a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Java"@en ;
    skos:notation "Java" ;
    skos:definition "Object-oriented programming language widely used for enterprise "
                    "backend services and APIs."@en ;
    skos:broader stf:SoftwareDevelopment .

stf:React a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "React"@en ;
    skos:altLabel "React.js"@en ;
    skos:notation "React" ;
    skos:definition "JavaScript library for building component-based user interfaces, "
                    "developed by Meta."@en ;
    skos:broader stf:SoftwareDevelopment .

stf:TypeScript a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "TypeScript"@en ;
    skos:altLabel "TS"@en ;
    skos:notation "TypeScript" ;
    skos:definition "Strongly-typed superset of JavaScript commonly used with React "
                    "and Node.js for large-scale web applications."@en ;
    skos:broader stf:SoftwareDevelopment .

stf:Microservices a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Microservices Architecture"@en ;
    skos:altLabel "Microservices"@en ;
    skos:notation "Microservices" ;
    skos:definition "Architectural style of building applications as suites of small, "
                    "independently deployable services communicating over APIs."@en ;
    skos:broader stf:SoftwareDevelopment .

# =============================================================================
# FUNCTIONAL SKILLS narrower concepts
# =============================================================================

stf:StrategyConsulting a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Strategy Consulting"@en ;
    skos:altLabel "Strategy"@en ;
    skos:notation "StrategyConsulting" ;
    skos:definition "Advising organisations on long-term direction, competitive "
                    "positioning, market entry, and operating model design."@en ;
    skos:broader stf:FunctionalSkills .

stf:ChangeManagement a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Change Management"@en ;
    skos:altLabel "OCM"@en ;
    skos:notation "ChangeManagement" ;
    skos:definition "Structured approach to transitioning individuals, teams and "
                    "organisations from a current state to a desired future state."@en ;
    skos:broader stf:FunctionalSkills .

stf:PMO a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Project Management Office"@en ;
    skos:altLabel "PMO"@en ;
    skos:notation "PMO" ;
    skos:definition "Governance function responsible for defining project management "
                    "standards, status reporting, and portfolio tracking."@en ;
    skos:broader stf:FunctionalSkills .

stf:BusinessAnalysis a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Business Analysis"@en ;
    skos:altLabel "BA"@en ;
    skos:notation "BusinessAnalysis" ;
    skos:definition "Identifying business needs and determining solutions, typically "
                    "through requirements gathering and process mapping."@en ;
    skos:broader stf:FunctionalSkills .

stf:ProcessImprovement a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Process Improvement"@en ;
    skos:altLabel "Lean Six Sigma"@en ;
    skos:altLabel "Lean"@en ;
    skos:notation "ProcessImprovement" ;
    skos:definition "Systematic approach to enhancing operational efficiency and "
                    "quality through Lean, Six Sigma, and related methodologies."@en ;
    skos:broader stf:FunctionalSkills .

# =============================================================================
# LEADERSHIP SKILLS narrower concepts
# =============================================================================

stf:TeamLeadership a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Team Leadership"@en ;
    skos:altLabel "Team Lead"@en ;
    skos:notation "TeamLeadership" ;
    skos:definition "The ability to motivate, guide and develop a team of consultants "
                    "towards a shared delivery objective."@en ;
    skos:broader stf:LeadershipSkills .

stf:StakeholderManagement a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Stakeholder Management"@en ;
    skos:notation "StakeholderManagement" ;
    skos:definition "Identifying, engaging and managing the expectations of project "
                    "stakeholders at all levels of seniority."@en ;
    skos:broader stf:LeadershipSkills .

stf:ExecutivePresence a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Executive Presence"@en ;
    skos:notation "ExecutivePresence" ;
    skos:definition "The combination of gravitas, communication skill and appearance "
                    "that conveys confidence and credibility to senior audiences."@en ;
    skos:broader stf:LeadershipSkills .

stf:ClientRelationships a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Client Relationships"@en ;
    skos:altLabel "Client Management"@en ;
    skos:notation "ClientRelationships" ;
    skos:definition "The ability to develop trusted, long-term relationships with "
                    "client executives and decision-makers."@en ;
    skos:broader stf:LeadershipSkills .

# Role label aliases (skos:altLabel on role-name concepts)
stf:ProjectManager a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Project Manager"@en ;
    skos:altLabel "PM"@en ;
    skos:altLabel "Proj Mgr"@en ;
    skos:altLabel "Project Manager"@en ;
    skos:notation "ProjectManager" ;
    skos:definition "A role responsible for end-to-end project planning, tracking, "
                    "risk management and delivery governance."@en ;
    skos:broader stf:FunctionalSkills .

stf:SeniorConsultant a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Senior Consultant"@en ;
    skos:altLabel "SC"@en ;
    skos:altLabel "Sr. Consultant"@en ;
    skos:notation "SeniorConsultant" ;
    skos:definition "A mid-senior consulting role with deep expertise in one or more "
                    "competency areas and the ability to lead workstreams."@en ;
    skos:broader stf:FunctionalSkills .

stf:DataEngineer a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Data Engineer"@en ;
    skos:altLabel "DE"@en ;
    skos:altLabel "Data Eng"@en ;
    skos:notation "DataEngineer" ;
    skos:definition "A technical role focused on building and maintaining data "
                    "pipelines, warehouses and streaming infrastructure."@en ;
    skos:broader stf:DataEngineering .

# =============================================================================
# DOMAIN SKILLS narrower concepts
# =============================================================================

stf:FinancialServices a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Financial Services"@en ;
    skos:altLabel "FinServ"@en ;
    skos:altLabel "FS"@en ;
    skos:notation "FinancialServices" ;
    skos:definition "Domain expertise spanning banking, insurance, asset management, "
                    "payments and capital markets."@en ;
    skos:broader stf:DomainSkills ;
    skos:narrower stf:Banking ;
    skos:narrower stf:AssetManagement ;
    skos:narrower stf:Insurance ;
    skos:narrower stf:Payments .

stf:Healthcare a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Healthcare"@en ;
    skos:altLabel "Health"@en ;
    skos:notation "Healthcare" ;
    skos:definition "Domain expertise in hospitals, payers, pharmaceuticals and "
                    "health tech including clinical and operational knowledge."@en ;
    skos:broader stf:DomainSkills .

stf:Energy a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Energy"@en ;
    skos:altLabel "Utilities"@en ;
    skos:notation "Energy" ;
    skos:definition "Domain expertise in oil & gas, renewables, utilities, grid "
                    "management and the energy transition."@en ;
    skos:broader stf:DomainSkills .

stf:Retail a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Retail"@en ;
    skos:altLabel "Consumer Retail"@en ;
    skos:notation "Retail" ;
    skos:definition "Domain expertise in consumer retail, e-commerce, supply chain "
                    "and omnichannel customer experience."@en ;
    skos:broader stf:DomainSkills .

stf:Technology a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Technology"@en ;
    skos:altLabel "Tech Industry"@en ;
    skos:notation "Technology" ;
    skos:definition "Domain expertise in technology companies, software vendors, "
                    "platform businesses and digital-native organisations."@en ;
    skos:broader stf:DomainSkills .

stf:Manufacturing a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Manufacturing"@en ;
    skos:altLabel "Industrial"@en ;
    skos:notation "Manufacturing" ;
    skos:definition "Domain expertise in discrete and process manufacturing, supply "
                    "chain management, and Industry 4.0 initiatives."@en ;
    skos:broader stf:DomainSkills .

# =============================================================================
# FINANCIAL SERVICES narrower concepts
# =============================================================================

stf:Banking a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Banking"@en ;
    skos:altLabel "Retail Banking"@en ;
    skos:altLabel "Corporate Banking"@en ;
    skos:notation "Banking" ;
    skos:definition "Expertise in retail banking, corporate banking, and investment "
                    "banking operations, products and regulation."@en ;
    skos:broader stf:FinancialServices .

stf:AssetManagement a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Asset Management"@en ;
    skos:altLabel "Investment Management"@en ;
    skos:altLabel "Buy Side"@en ;
    skos:notation "AssetManagement" ;
    skos:definition "Expertise in portfolio management, fund operations, "
                    "performance reporting and investment compliance."@en ;
    skos:broader stf:FinancialServices .

stf:Insurance a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Insurance"@en ;
    skos:altLabel "P&C"@en ;
    skos:notation "Insurance" ;
    skos:definition "Expertise in property & casualty, life and health insurance "
                    "products, underwriting and claims operations."@en ;
    skos:broader stf:FinancialServices .

stf:Payments a skos:Concept ;
    skos:inScheme stf:SkillScheme ;
    skos:prefLabel "Payments"@en ;
    skos:altLabel "FinTech Payments"@en ;
    skos:notation "Payments" ;
    skos:definition "Expertise in payment rails, card schemes, open banking, "
                    "instant payments and payment technology platforms."@en ;
    skos:broader stf:FinancialServices .
