    rdfs:label            "Core Banking Modernisation"@en ;
    stf:engagementIndustry "FinTech"^^xsd:string ;
    stf:engagementSector   "Banking"^^xsd:string ;
    stf:engagementFunction "Technology"^^xsd:string ;
    stf:projectStartDate  "2025-01-15"^^xsd:date ;
    stf:projectEndDate    "2026-06-30"^^xsd:date ;
    stf:hasTeam           inst:team-novapay-dataeng .

inst:proj-medcore-healthrecords a stf:ClientEngagement ;
    stf:projectCode       "PROJ-HC-2025-002"^^xsd:string ;
    rdfs:label            "Digital Health Records Platform"@en ;
    stf:engagementIndustry "Healthcare"^^xsd:string ;
