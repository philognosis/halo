# =============================================================================
# LOCATIONS
# =============================================================================

inst:location-london a stf:Location, geo:Feature ;
    rdfs:label "London, United Kingdom"@en ;
    geo:asWKT "POINT(-0.1276 51.5074)"^^geo:wktLiteral .

inst:location-mumbai a stf:Location, geo:Feature ;
    rdfs:label "Mumbai, India"@en ;
    geo:asWKT "POINT(72.8777 19.0760)"^^geo:wktLiteral .

