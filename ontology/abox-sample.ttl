# =============================================================================
# TEAMS
# =============================================================================

inst:team-novapay-dataeng a stf:ProjectTeam ;
    rdfs:label "Core Banking Data Team"@en ;
    stf:hasOpportunity inst:opp-senior-data-engineer ;
    stf:hasStaffedSeat inst:person-rajan-mehta ;
    stf:hasStaffedSeat inst:person-luca-rossi .   # second seat for SHACL team-size rule

inst:team-medcore-platform a stf:ProjectTeam ;
    rdfs:label "Platform Engineering Team"@en ;
    stf:hasOpportunity inst:opp-cloud-architect ;
    stf:hasStaffedSeat inst:person-priya-sharma ;
    stf:hasStaffedSeat inst:person-rajan-mehta .   # shared resource (20% overlap - illustrative)

# =============================================================================
# OPPORTUNITIES
# =============================================================================

inst:opp-senior-data-engineer a stf:Opportunity ;
    stf:opportunityRole "Senior Data Engineer"^^xsd:string ;
    stf:requiredBand    "Senior Consultant"^^xsd:string ;
    stf:allocationStart "2025-07-01"^^xsd:date ;
    stf:allocationEnd   "2026-06-30"^^xsd:date ;
    stf:assignmentStatus "filled"^^xsd:string .

inst:opp-cloud-architect a stf:Opportunity ;
    stf:opportunityRole "Cloud Solutions Architect"^^xsd:string ;
    stf:requiredBand    "Manager"^^xsd:string ;
    stf:allocationStart "2025-06-01"^^xsd:date ;
    stf:allocationEnd   "2026-09-30"^^xsd:date ;
    stf:assignmentStatus "filled"^^xsd:string .

# =============================================================================
# PROJECT ALLOCATIONS (Relators)
# =============================================================================

inst:alloc-rajan-novapay a stf:ProjectAllocation ;
    rdfs:label            "Rajan Mehta → NovaPay Core Banking Data Team"@en ;
    stf:allocatedEmployee    inst:person-rajan-mehta ;
    stf:allocatedToOpportunity inst:opp-senior-data-engineer ;
    stf:allocationStart      "2025-07-01"^^xsd:date ;
    stf:allocationEnd        "2026-06-30"^^xsd:date ;
    stf:allocationPct        "100"^^xsd:decimal ;
    stf:assignmentStatus     "staffed"^^xsd:string ;
    stf:approvedBy           inst:person-thomas-becker-ref ;
    prov:wasGeneratedBy      inst:approval-rajan-novapay ;
    prov:wasAttributedTo     inst:person-thomas-becker-ref .

# Inverse link from employee
inst:person-rajan-mehta stf:isStaffedOn inst:alloc-rajan-novapay ;
                        stf:hasActiveAllocation inst:alloc-rajan-novapay .

inst:alloc-priya-medcore a stf:ProjectAllocation ;
    rdfs:label            "Priya Sharma → MedCore Digital Health Platform Team"@en ;
    stf:allocatedEmployee    inst:person-priya-sharma ;
    stf:allocatedToOpportunity inst:opp-cloud-architect ;
    stf:allocationStart      "2025-06-01"^^xsd:date ;
    stf:allocationEnd        "2026-09-30"^^xsd:date ;
    stf:allocationPct        "100"^^xsd:decimal ;
    stf:assignmentStatus     "staffed"^^xsd:string ;
    stf:approvedBy           inst:person-amelia-hartley-ref ;
    prov:wasGeneratedBy      inst:approval-priya-medcore ;
    prov:wasAttributedTo     inst:person-amelia-hartley-ref .

inst:person-priya-sharma stf:isStaffedOn inst:alloc-priya-medcore ;
                         stf:hasActiveAllocation inst:alloc-priya-medcore .

# =============================================================================
# PROV-DM PROVENANCE TRIPLES
# Demonstrates the Postgres prov_log → Jena PROV-DM projection pattern.
# Full provenance for inst:alloc-rajan-novapay
# =============================================================================

# ApprovalEvent (prov:Activity)
inst:approval-rajan-novapay a stf:ApprovalEvent, prov:Activity ;
    rdfs:label "Staffing Approval: Rajan Mehta onto NovaPay Core Banking Data Team"@en ;
    prov:startedAtTime   "2025-06-10T09:00:00Z"^^xsd:dateTime ;
    prov:endedAtTime     "2025-06-10T09:05:00Z"^^xsd:dateTime ;
    prov:wasAssociatedWith inst:person-thomas-becker-ref ;
    rdfs:comment "Thomas Becker (Delivery Lead) reviewed and approved the staffing of Rajan Mehta to the Senior Data Engineer role. Databricks certification and Spark expertise confirmed."@en .

# The allocation entity was generated by the approval activity
inst:alloc-rajan-novapay prov:wasGeneratedBy inst:approval-rajan-novapay ;
    prov:generatedAtTime "2025-06-10T09:05:00Z"^^xsd:dateTime ;
    prov:wasAttributedTo inst:person-thomas-becker-ref .

# Reference to the approver (Thomas Becker from seed data)
inst:person-thomas-becker-ref a stf:Person, prov:Agent ;
    stf:hasName  "Thomas Becker"^^xsd:string ;
    stf:hasEmail "thomas.becker@enterprise.org"^^xsd:string ;
    stf:hasBand  "Senior Manager"^^xsd:string .

# Reference to the partner (Amelia Hartley) for MedCore approval
inst:person-amelia-hartley-ref a stf:Person, prov:Agent ;
    stf:hasName  "Amelia Hartley"^^xsd:string ;
    stf:hasEmail "amelia.hartley@enterprise.org"^^xsd:string ;
    stf:hasBand  "Partner"^^xsd:string .

# ApprovalEvent for Priya's allocation
inst:approval-priya-medcore a stf:ApprovalEvent, prov:Activity ;
    rdfs:label "Staffing Approval: Priya Sharma onto MedCore Platform Engineering Team"@en ;
    prov:startedAtTime   "2025-05-15T14:00:00Z"^^xsd:dateTime ;
    prov:endedAtTime     "2025-05-15T14:08:00Z"^^xsd:dateTime ;
    prov:wasAssociatedWith inst:person-amelia-hartley-ref ;
    rdfs:comment "Amelia Hartley (Engagement Partner) approved Priya Sharma as Cloud Solutions Architect. AWS certification and healthcare domain knowledge verified against opportunity requirements."@en .

inst:alloc-priya-medcore prov:wasGeneratedBy inst:approval-priya-medcore ;
    prov:generatedAtTime "2025-05-15T14:08:00Z"^^xsd:dateTime ;
    prov:wasAttributedTo inst:person-amelia-hartley-ref .
