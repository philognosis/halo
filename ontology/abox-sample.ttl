# Teams:     Core Banking Data Team, MedCore Platform Engineering
# Opportunities: Senior Data Engineer (NovaPay), Cloud Solutions Architect (MedCore)
# Assignments:   Rajan → NovaPay, Priya → MedCore
# =============================================================================

# =============================================================================
# PERSONS
# =============================================================================

inst:person-priya-sharma a stf:Person, stf:Consultant ;
