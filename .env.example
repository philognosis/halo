# PostgreSQL
POSTGRES_DB=staffingdb
POSTGRES_USER=staffing
POSTGRES_PASSWORD=staffing-changeme

# Apache Jena Fuseki
FUSEKI_ADMIN_PASSWORD=admin-changeme

# FastAPI / Worker / pg-listener (full connection strings)
# Note: DATABASE_URL uses the internal Docker network address (postgres:5432).
# To connect from the host (e.g. psql, DBeaver) use port 5433.
DATABASE_URL=postgresql://staffing:staffing-changeme@postgres:5432/staffingdb
FUSEKI_ENDPOINT=http://fuseki:3030/staffing

# Anthropic (optional — system works without it using deterministic fallbacks)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# PgAdmin (optional — only used with: docker-compose --profile tools up)
PGADMIN_EMAIL=admin@staffing.local
PGADMIN_PASSWORD=pgadmin-changeme
